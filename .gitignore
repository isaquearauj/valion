# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Supabase CLI credentials/config must never be committed.
.env.supabase

# package managers
/package-lock.json

# local AI tooling metadata
/.opencode/
/.cursor/
/.claude/*
!/.claude/agents
!/.claude/skills
/.codex/*
!/.codex/agents/
!/.codex/agents/*.toml
/.agents/skills/*-workspace/
/.context/
/.windsurf/
/docs/specs/
/.pnpm-store/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
