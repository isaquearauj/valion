{
  "name": "valion",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": "22.x"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "msw",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss": "8.5.19"
    }
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "preinstall": "node scripts/check-node-version.mjs",
    "dev": "pnpm check:node && next dev",
    "dev:all": "pnpm supabase:start && pnpm dev",
    "build": "pnpm check:node && next build",
    "start": "next start",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome lint .",
    "lint:eslint": "eslint app components features lib tests scripts --cache --cache-location node_modules/.cache/eslint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "quality": "pnpm check:node && pnpm check && pnpm lint:eslint && pnpm typecheck && pnpm test",
    "verify": "pnpm quality && pnpm build",
    "verify:supabase": "pnpm supabase:reset && pnpm test:supabase",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:supabase": "vitest run --config vitest.supabase.config.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset --local",
    "supabase:seed": "node scripts/seed-local.mjs",
    "supabase:reset:seed": "pnpm supabase:reset && pnpm supabase:seed",
    "supabase:status": "supabase status",
    "supabase:types": "node scripts/generate-supabase-types.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "shadcn": "^4.13.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
